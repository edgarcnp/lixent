---
import LicenseLayout from "../layouts/LicenseLayout.astro"
import LicenseBody from "../components/LicenseBody.astro"
import { loadConfig } from "../lib/config/index.ts"
import { resolveLicense, renderLicenseText } from "../lib/license.ts"
import { formatYear, formatYearRange } from "../lib/year.ts"

const config = loadConfig()

let yearStr: string
if (config.year != null) {
    yearStr = formatYear(config.year)
} else if (config.yearRange != null) {
    yearStr = formatYearRange(config.yearRange.start, config.yearRange.end)
} else {
    yearStr = formatYear()
}

const license = await resolveLicense(config)
const renderedText = renderLicenseText(license.text, {
    year: yearStr,
    name: config.copyright,
    url: config.url,
    email: config.email,
})
---

<LicenseLayout title={license.name} config={config} yearStr={yearStr}>
    <LicenseBody text={renderedText} />
</LicenseLayout>
