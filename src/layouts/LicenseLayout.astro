---
import { Image } from "astro:assets"
import { loadConfig } from "../lib/config.ts"
import { getGravatarUrl } from "../lib/gravatar.ts"
import { formatYear, formatYearRange } from "../lib/year.ts"
import { getTheme, themes } from "../themes/index.ts"
import "../styles/base.css"

const CSS_DANGEROUS = /[;{}]|url\s*\(/i
const ALLOWED_KEYS = themes.flatMap((t) => t.variables)

interface Props {
    title: string
    copyright?: string
}

const { title, copyright } = Astro.props
const config = loadConfig()

const builtInTheme = getTheme(config.theme)
const themePath
    = builtInTheme != null || !config.theme.startsWith("/")
        ? `/themes/${config.theme}.css`
        : config.theme

function sanitizeCssValue(v: string): string {
    return v.replace(/[;{}]/g, "").replace(/url\s*\(/gi, "")
}

const themeOverrides
    = config.themeOverrides != null
        ? Object.entries(config.themeOverrides)
            .filter(([k]) => ALLOWED_KEYS.includes(k))
            .map(([k, v]) => CSS_DANGEROUS.test(v) ? "" : `${k}: ${sanitizeCssValue(v)};`)
            .join(" ")
        : ""

const fontValue = config.font != null && config.font.length > 0 && !CSS_DANGEROUS.test(config.font)
    ? sanitizeCssValue(config.font)
    : ""

const fontOverride = fontValue.length > 0
    ? `--lx-font-body: ${fontValue};`
    : ""

const name = copyright ?? config.copyright

let yearStr: string
if (config.year != null) {
    yearStr = formatYear(config.year)
} else if (config.yearRange != null) {
    yearStr = formatYearRange(config.yearRange.start, config.yearRange.end)
} else {
    yearStr = formatYear()
}

const hasUrl = config.url != null && config.url.length > 0
const hasEmail = config.email != null && config.email.length > 0

const gravatarUrl
    = config.gravatar === true && hasEmail && config.email != null
        ? getGravatarUrl(config.email, 64)
        : null;
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="icon" href="/favicon.ico" />
        <meta name="generator" content={Astro.generator} />
        <title>{title}</title>
        <link rel="stylesheet" href={themePath} />
        {/* eslint-disable-next-line astro/no-set-html-directive -- User-controlled theme overrides are safe */}
        {themeOverrides && <style set:html={`:root { ${themeOverrides} }`} />}
        {/* eslint-disable-next-line astro/no-set-html-directive -- User-controlled font override is safe */}
        {fontOverride && <style set:html={`:root { ${fontOverride} }`} />}
    </head>
    <body>
        <main>
            <div class="islands">
                <article class="license-card identity-card">
                    <header class="license-header">
                        {gravatarUrl && (
                            <Image
                                class="gravatar"
                                src={gravatarUrl}
                                alt={config.copyright}
                                width={64}
                                height={64}
                                loading="eager"
                            />
                        )}
                        <h1>{title}</h1>
                        <p class="copyright">
                            Copyright &copy; {yearStr}{" "}
                            {hasUrl
                                ? <a href={config.url} target="_blank" rel="noopener noreferrer">{name}</a>
                                : name
                            }
                            {hasEmail && (
                                <span class="email"> &lt;<a href={`mailto:${config.email}`}>{config.email}</a>&gt;</span>
                            )}
                        </p>
                    </header>
                </article>
                <article class="license-card content-card">
                    <div class="license-content">
                        <slot />
                    </div>
                </article>
            </div>
        </main>
        <footer>
            <span class="footer-pill">
                Powered by <a href="https://github.com/edgarcnp/lixent">Lixent</a>
            </span>
        </footer>
    </body>
</html>
