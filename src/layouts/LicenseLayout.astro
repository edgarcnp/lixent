---
import { Image } from "astro:assets"
import { getGravatarUrl } from "../lib/gravatar.ts"
import { formatYear, formatYearRange } from "../lib/year.ts"
import { CSS_DANGEROUS_PATTERN } from "../lib/validation.ts"
import { getGoogleFontsUrl } from "../lib/font.ts"
import { getTheme, THEME_VARIABLES } from "../themes/index.ts"
import type { LixentConfig } from "../lib/types.ts"
import "../styles/base.css"

interface Props {
    title: string
    config: LixentConfig
    copyright?: string
}

const { title, config, copyright } = Astro.props

const builtInTheme = getTheme(config.theme)
const themePath
    = builtInTheme != null || !config.theme.startsWith("/")
        ? `/themes/${config.theme}.css`
        : config.theme

function sanitizeCssValue(v: string): string {
    return v.replace(/[;{}]/g, "").replace(/url\s*\(/gi, "")
}

const themeOverrides
    = config.themeOverrides != null
        ? Object.entries(config.themeOverrides)
            .filter(([k]) => THEME_VARIABLES.includes(k))
            .map(([k, v]) => CSS_DANGEROUS_PATTERN.test(v) ? "" : `${k}: ${sanitizeCssValue(v)};`)
            .join(" ")
        : ""

const rawFont = config.font
const fontValue = rawFont != null && rawFont.length > 0 && !CSS_DANGEROUS_PATTERN.test(rawFont)
    ? sanitizeCssValue(rawFont)
    : ""

const fontOverrideParts: string[] = []
if (fontValue.length > 0) {
    fontOverrideParts.push(`--lx-font-body: ${fontValue};`)
}
if (config.fontSize != null && config.fontSize.length > 0) {
    fontOverrideParts.push(`--lx-font-size: ${config.fontSize};`)
}
if (config.fontWeight != null && config.fontWeight.length > 0) {
    fontOverrideParts.push(`font-weight: ${config.fontWeight};`)
}
if (config.lineHeight != null && config.lineHeight.length > 0) {
    fontOverrideParts.push(`--lx-line-height: ${config.lineHeight};`)
}
if (config.letterSpacing != null && config.letterSpacing.length > 0) {
    fontOverrideParts.push(`letter-spacing: ${config.letterSpacing};`)
}
const fontOverride = fontOverrideParts.length > 0
    ? fontOverrideParts.join(" ")
    : ""

const googleFontsUrl = rawFont != null && rawFont.length > 0 ? getGoogleFontsUrl(rawFont) : null

const name = copyright ?? config.copyright

let yearStr: string
if (config.year != null) {
    yearStr = formatYear(config.year)
} else if (config.yearRange != null) {
    yearStr = formatYearRange(config.yearRange.start, config.yearRange.end)
} else {
    yearStr = formatYear()
}

const hasUrl = config.url != null && config.url.length > 0
const hasEmail = config.email != null && config.email.length > 0

const gravatarUrl
    = config.gravatar === true && hasEmail && config.email != null
        ? getGravatarUrl(config.email, 64)
        : null;
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="icon" href="/favicon.ico" />
        <meta name="generator" content={Astro.generator} />
        <title>{title}</title>
        {googleFontsUrl && <link rel="preconnect" href="https://fonts.googleapis.com" />}
        {googleFontsUrl && <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />}
        {googleFontsUrl && <link rel="stylesheet" href={googleFontsUrl} />}
        <link rel="stylesheet" href={themePath} />
        {/* eslint-disable-next-line astro/no-set-html-directive -- User-controlled theme overrides are safe */}
        {themeOverrides && <style set:html={`:root { ${themeOverrides} }`} />}
        {/* eslint-disable-next-line astro/no-set-html-directive -- User-controlled font overrides are safe */}
        {fontOverride && <style set:html={`body { ${fontOverride} }`} />}
    </head>
    <body>
        <main>
            <div class="islands">
                <article class="license-card identity-card">
                    <header class="license-header">
                        {gravatarUrl && (
                            <Image
                                class="gravatar"
                                src={gravatarUrl}
                                alt={config.copyright}
                                width={64}
                                height={64}
                                loading="eager"
                            />
                        )}
                        <h1>{title}</h1>
                        <p class="copyright">
                            Copyright &copy; {yearStr}{" "}
                            {hasUrl
                                ? <a href={config.url} target="_blank" rel="noopener noreferrer">{name}</a>
                                : name
                            }
                            {hasEmail && (
                                <span class="email"> &lt;<a href={`mailto:${config.email}`}>{config.email}</a>&gt;</span>
                            )}
                        </p>
                    </header>
                </article>
                <article class="license-card content-card">
                    <div class="license-content">
                        <slot />
                    </div>
                </article>
            </div>
        </main>
        <footer>
            <span class="footer-pill">
                Powered by <a href="https://github.com/edgarcnp/lixent">Lixent</a>
            </span>
        </footer>
    </body>
</html>
